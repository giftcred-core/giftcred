# Backend API base URL (include /api suffix).
#
# Local dev — leave commented to use Vite proxy (/api → http://127.0.0.1:8000):
# VITE_API_URL=
#
# Point at your whitelisted VPS API (local or production testing):
# VITE_API_URL=https://api.yourdomain.com/api
# VITE_API_URL=http://YOUR_VPS_IP:8000/api
#
# Vercel: set the same variable in Project → Environment Variables (build-time).
