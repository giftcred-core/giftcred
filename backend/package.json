    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "ipaddr.js": "^2.2.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.16",
    "oauth-1.0a": "^2.2.6",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
