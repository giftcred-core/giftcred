# Woohoo / Qwikcilver Sandbox OAuth credentials
WOOHOO_CONSUMER_KEY=
WOOHOO_CONSUMER_SECRET=
WOOHOO_USERNAME=
WOOHOO_PASSWORD=

# Woohoo API base URL
WOOHOO_BASE_URL=https://sandbox.woohoo.in

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=woohoo_catalog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# HTTP / retry settings
WOOHOO_REQUEST_TIMEOUT=30
WOOHOO_MAX_RETRIES=3
LOG_LEVEL=INFO

# JWT (must match auth-api JWT_SECRET)
JWT_SECRET=change-me-access-secret-min-32-chars
