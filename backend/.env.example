# Server
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# PostgreSQL (auth + woohoo tables)
DATABASE_URL=postgresql://user:password@host:5432/giftcred_auth

# Redis (optional in dev)
REDIS_URL=redis://localhost:6379
REDIS_OPTIONAL=true

# JWT
JWT_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Email (OTP + invites)
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM=GiftCred <noreply@giftcred.com>

# Google SSO
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/sso/google/callback

# Microsoft SSO
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_CALLBACK_URL=http://localhost:3001/api/auth/sso/microsoft/callback

# Woohoo / Qwikcilver (ported from Python backend)
WOOHOO_CONSUMER_KEY=
WOOHOO_CONSUMER_SECRET=
WOOHOO_USERNAME=
WOOHOO_PASSWORD=
WOOHOO_BASE_URL=https://sandbox.woohoo.in
WOOHOO_REQUEST_TIMEOUT=30
WOOHOO_MAX_RETRIES=3

# E2E / Jest tests
E2E_ADMIN_EMAIL=admin@giftcred.com
E2E_ADMIN_PASSWORD=Giftcred@123
