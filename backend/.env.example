# Woohoo / Qwikcilver Sandbox OAuth2 credentials
# CONSUMER_KEY/SECRET = clientId/clientSecret (API signing)
# USERNAME/PASSWORD = sandbox login for /oauth2/verify
WOOHOO_CONSUMER_KEY=
WOOHOO_CONSUMER_SECRET=
WOOHOO_USERNAME=
WOOHOO_PASSWORD=

WOOHOO_BASE_URL=https://sandbox.woohoo.in
WOOHOO_AUTH_MODE=oauth2
WOOHOO_OAUTH2_VERIFY_URL=https://sandbox.woohoo.in/oauth2/verify
WOOHOO_OAUTH2_TOKEN_URL=https://sandbox.woohoo.in/oauth2/token
WOOHOO_REQUEST_SIGNATURE_HEADER=signature
WOOHOO_SIGNATURE_JSON_PRETTY=false

# PostgreSQL
DATABASE_URL=postgres://user:password@host:5432/dbname

# HTTP / retry settings
WOOHOO_REQUEST_TIMEOUT=60
WOOHOO_MAX_RETRIES=3
LOG_LEVEL=INFO
