# Woohoo / Qwikcilver — same variables as backend-python/.env.example
# Local dev: copy backend-python/.env here OR keep it in backend-python/.env (Express loads both)
WOOHOO_CONSUMER_KEY=
WOOHOO_CONSUMER_SECRET=
WOOHOO_USERNAME=
WOOHOO_PASSWORD=

WOOHOO_BASE_URL=https://sandbox.woohoo.in
WOOHOO_AUTH_MODE=oauth2
WOOHOO_OAUTH2_VERIFY_URL=https://sandbox.woohoo.in/oauth2/verify
WOOHOO_OAUTH2_TOKEN_URL=https://sandbox.woohoo.in/oauth2/token
WOOHOO_REQUEST_SIGNATURE_HEADER=signature
WOOHOO_SIGNATURE_JSON_PRETTY=false

# PostgreSQL (Neon, Supabase, Vercel Postgres, etc.)
DATABASE_URL=postgres://user:password@host:5432/dbname

WOOHOO_REQUEST_TIMEOUT=60
WOOHOO_MAX_RETRIES=3
LOG_LEVEL=INFO

# Optional — catalog cache TTL in hours (default 720 = ~30 days, once per month)
# CATALOG_CACHE_TTL_HOURS=720

# Optional — comma-separated origins for CORS (defaults to *)
# CORS_ORIGINS=https://your-app.vercel.app
