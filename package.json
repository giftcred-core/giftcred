{
  "name": "giftcred",
  "private": true,
  "version": "1.0.0",
  "description": "Giftcred — React frontend + Node.js Express backend",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:frontend": "cd frontend && npm install && npm run build",
    "dev": "tsx backend/server.ts",
    "dev:api": "tsx backend/server.ts",
    "start": "tsx backend/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.3",
    "sanitize-html": "^2.14.0",
    "tsx": "^4.19.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "@types/sanitize-html": "^2.13.0",
    "typescript": "^5.8.2"
  }
}
