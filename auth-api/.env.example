# Server
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@89.167.107.138:5432/giftcred_auth

# Redis (role cache, OTP rate limiting). Set REDIS_OPTIONAL=true to start without Redis in dev.
REDIS_URL=redis://localhost:6379
REDIS_OPTIONAL=true

# JWT
JWT_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Gmail SMTP (OTP + invite emails)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your-app-password
EMAIL_FROM=GiftCred <your@gmail.com>

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/sso/google/callback

# Microsoft Azure AD
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:3001/api/auth/sso/microsoft/callback
MICROSOFT_TENANT_ID=common

# Invite tokens
INVITE_TOKEN_TTL_HOURS=48
OTP_TTL_MINUTES=10
ROLE_CACHE_TTL_SECONDS=1800
